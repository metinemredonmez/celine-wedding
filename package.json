{
  "name": "celine-wedding",
  "version": "0.1.0",
  "private": true,
  "description": "Celine Gelinlik — luxury bridal boutique showcase site (celinegelinlik.com)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,yaml,yml}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
