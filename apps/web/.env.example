# apps/web — Next.js
# Gerçek değerleri .env.local'e koy (commit edilmez). Bu dosya sadece anahtar sözleşmesidir.

# ---- Public (tarayıcıya açık, NEXT_PUBLIC_*) ----
NEXT_PUBLIC_SITE_URL=https://celinegelinlik.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=CHANGEME
NEXT_PUBLIC_WHATSAPP_PHONE=90XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=celinegelinlik.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHANGEME

# ---- Server-only (tarayıcıya ASLA sızmaz) ----
NEST_API_URL=http://localhost:3001          # prod: https://api.celinegelinlik.com
INTERNAL_API_KEY=CHANGEME                    # web BFF -> NestJS ortak anahtar
REVALIDATE_SECRET=CHANGEME                   # NestJS -> /api/revalidate webhook
TURNSTILE_SECRET_KEY=CHANGEME
