# apps/web — Next.js (Celine Gelinlik frontend)
# Gerçek değerleri .env.local'e koy (commit edilmez). Bu dosya sadece anahtar sözleşmesidir.

# ---- Public (tarayıcıya açık, NEXT_PUBLIC_*) ----
# NestJS API tabanı — sunucu tarafı fetch bunu kullanır.
# prod: https://api.celinegelinlik.com | dev: http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=https://celinegelinlik.com
# WhatsApp numarası (uluslararası, + ve boşluk yok). Örn: 905XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_PHONE=905XXXXXXXXX
# Instagram kullanıcı adı (@ olmadan) veya tam URL.
NEXT_PUBLIC_INSTAGRAM=celinegelinlik
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=CHANGEME
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=celinegelinlik.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHANGEME

# ---- Server-only (tarayıcıya ASLA sızmaz) ----
INTERNAL_API_KEY=CHANGEME                    # web -> NestJS ortak anahtar (gerekirse)
REVALIDATE_SECRET=CHANGEME                   # NestJS -> /api/revalidate webhook
TURNSTILE_SECRET_KEY=CHANGEME
