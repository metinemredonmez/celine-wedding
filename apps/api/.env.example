# apps/api — NestJS
# Gerçek değerleri .env'e koy (commit edilmez). Bu dosya sadece anahtar sözleşmesidir.

# ---- Runtime ----
NODE_ENV=development
PORT=3001

# ---- Database (Prisma / PostgreSQL) ----
DATABASE_URL=postgresql://celine:CHANGEME@localhost:5432/celine?schema=public
POSTGRES_PASSWORD=CHANGEME

# ---- Auth (argon2 + JWT access/refresh) ----
JWT_ACCESS_SECRET=CHANGEME
JWT_REFRESH_SECRET=CHANGEME
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- İlk admin (seed) ----
ADMIN_EMAIL=seda@celinegelinlik.com
ADMIN_PASSWORD=CHANGEME

# ---- Cloudinary (görsel CDN, source of truth) ----
CLOUDINARY_CLOUD_NAME=CHANGEME
CLOUDINARY_API_KEY=CHANGEME
CLOUDINARY_API_SECRET=CHANGEME

# ---- Web entegrasyonu ----
WEB_ORIGIN=http://localhost:3000            # CORS (prod: https://celinegelinlik.com)
INTERNAL_API_KEY=CHANGEME                   # web ile aynı olmalı
REVALIDATE_WEBHOOK_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=CHANGEME                  # web ile aynı olmalı
