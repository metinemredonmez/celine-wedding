// Celine Gelinlik — Prisma schema
//
// NOTE: docs/DATA-MODEL.md targets the Prisma 7 bleeding-edge `prisma-client`
// generator with a custom `output`. For this first, basic push we deliberately
// use the STABLE `prisma-client-js` generator (default output into node_modules,
// imported from `@prisma/client`) for reliability.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────

enum DressStatus {
  DRAFT
  PUBLISHED
}

enum AppointmentStatus {
  NEW
  CONTACTED
  DONE
  CANCELLED
}

enum AdminRole {
  ADMIN
}

enum TryOnStatus {
  PENDING
  DONE
  FAILED
}

// ────────────────────────── MODELS ───────────────────────────

model Collection {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dresses Dress[]

  @@index([order])
  @@map("collections")
}

model Dress {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  price       Decimal?    @db.Decimal(10, 2)
  fabric      String?
  details     String?
  status      DressStatus @default(DRAFT)
  featured    Boolean     @default(false)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  images        Image[]
  tryOnRequests TryOnRequest[]

  @@index([status, featured, order])
  @@index([collectionId, status])
  @@index([slug])
  @@map("dresses")
}

model Image {
  id        String   @id @default(cuid())
  url       String
  publicId  String   @unique
  alt       String?
  width     Int?
  height    Int?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  dressId String
  dress   Dress  @relation(fields: [dressId], references: [id], onDelete: Cascade)

  @@index([dressId, order])
  @@map("images")
}

model Appointment {
  id            String            @id @default(cuid())
  name          String
  phone         String
  email         String?
  preferredDate DateTime? // free-form preferred date (legacy / no calendar)
  startsAt      DateTime? // booked calendar slot start
  durationMin   Int?              @default(60)
  message       String?
  status        AppointmentStatus @default(NEW)
  createdAt     DateTime          @default(now())

  @@index([status, createdAt])
  @@index([startsAt])
  @@map("appointments")
}

model AdminUser {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  role             AdminRole @default(ADMIN)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("admin_users")
}

model SiteSettings {
  id        String   @id @default("singleton")
  phone     String?
  whatsapp  String?
  instagram String?
  address   String?
  mapUrl    String?
  about     String?  @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─────────────── Calendar / booking availability ───────────────

// Weekly recurring availability (e.g. Mon–Sat 10:00–19:00, 60-min slots).
model AvailabilityRule {
  id           String   @id @default(cuid())
  weekday      Int // 0 = Sunday .. 6 = Saturday
  startMinutes Int // minutes from midnight, e.g. 600 = 10:00
  endMinutes   Int // e.g. 1140 = 19:00
  slotMinutes  Int      @default(60)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([weekday, active])
  @@map("availability_rules")
}

// Full-day closures (holidays, kapalı günler) that override the weekly rules.
model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([date])
  @@map("blocked_dates")
}

// Virtual Try-On (AI). Provider-agnostic — see docs/VIRTUAL-TRYON.md.
model TryOnRequest {
  id              String      @id @default(cuid())
  personImageUrl  String
  garmentImageUrl String
  resultUrl       String?
  status          TryOnStatus @default(PENDING)
  provider        String?
  error           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  dressId String?
  dress   Dress?  @relation(fields: [dressId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("try_on_requests")
}
